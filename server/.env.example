# Copy to .env and fill in values (do not commit .env with real tokens)

SECRET_KEY=change-this-secret-key-in-production

# Bale bot token from https://ble.ir/adsMonitorNotifBot
BALE_BOT_TOKEN=your_token_here

# Minutes without agent report before "offline" alert
AGENT_OFFLINE_MINUTES=5

# Optional: default Bale group chat id (use @username format for groups)
# BALE_DEFAULT_CHAT_ID=@your_group_id
